{
  "name": "@numkeys/rp-sdk",
  "version": "0.2.0",
  "description": "Relying-Party SDK for the Numkeys Protocol v1.2 — transport-agnostic attestation requests (popup, browser extension, QR, redirect).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitnob/numkeys-rp-sdk.git"
  },
  "homepage": "https://github.com/bitnob/numkeys-rp-sdk#readme",
  "bugs": {
    "url": "https://github.com/bitnob/numkeys-rp-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "zod": "^3.25.76",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "jose": "^5.9.6"
  }
}
